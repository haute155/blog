---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SearchModal from "../components/SearchModal.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

interface Props {
  title?: string;
  description?: string;
  /** OpenGraph 타입 — 글 상세 페이지에서는 "article" */
  ogType?: "website" | "article";
  /** OG 이미지 경로 (사이트 루트 기준) */
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogType = "website",
  image = "/og-default.png",
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />

    <!-- OpenGraph -->
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content="ko_KR" />
    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime.toISOString()} />
      )
    }
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <meta name="theme-color" content="#007FFF" />
    <ClientRouter />

    <!-- FOUC 방지: 첫 페인트 전에 저장된 테마를 적용해야 해서 인라인으로 실행 -->
    <script is:inline>
      (function () {
        function applyTheme() {
          const stored = localStorage.getItem("theme");
          const theme =
            stored ?? (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
        }
        applyTheme();
        // View Transitions가 <html> 속성을 새 페이지 것으로 교체하므로 다시 적용
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <a
      href="#main"
      class="focus:bg-brand sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-full focus:px-4 focus:py-2 focus:font-bold focus:text-white"
    >
      본문으로 건너뛰기
    </a>
    <div class="flex min-h-screen flex-col">
      <Header />
      <main id="main" class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
    <SearchModal />
  </body>
</html>
