---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllSeries } from "../../utils/series";
import { formatDate } from "../../utils/date";
import { getReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const allSeries = await getAllSeries();

  return allSeries.map((series) => ({
    params: { series: series.id },
    props: { series },
  }));
}

const { series } = Astro.props;
---

<BaseLayout
  title={`${series.name} | Azure Notes`}
  description={series.description ?? `"${series.name}" 시리즈 전체 ${series.posts.length}편`}
>
  <section class="pt-8 pb-16">
    <div class="container max-w-[760px]">
      <div class="mb-8">
        <a
          href="/series"
          class="text-muted hover:text-brand text-sm font-semibold transition-colors"
        >
          ← 전체 시리즈
        </a>
        <h1 class="mt-3 mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">
          {series.name}
        </h1>
        {series.description && <p class="text-muted">{series.description}</p>}
        <p class="text-muted mt-1 text-sm">
          전체 {series.posts.length}편 · 1편부터 순서대로 읽는 것을 추천해요.
        </p>
      </div>

      <ol class="space-y-4">
        {
          series.posts.map((post, i) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="border-line-brand bg-surface/90 shadow-card hover:border-brand/25 flex gap-5 rounded-2xl border p-6 transition duration-200 hover:-translate-y-0.5"
              >
                <span class="text-brand text-3xl leading-none font-extrabold">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="min-w-0">
                  <h2 class="text-text text-lg leading-snug font-bold">{post.data.title}</h2>
                  <p class="text-muted mt-1 text-sm">{post.data.description}</p>
                  <p class="text-muted mt-2 text-xs">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <span aria-hidden="true"> · </span>
                    {getReadingTime(post.body)}분 읽기
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</BaseLayout>
