---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllSeries } from "../../utils/series";
import { formatDate } from "../../utils/date";

const allSeries = await getAllSeries();
---

<BaseLayout title="Series" description="하나의 주제를 순서대로 파고드는 연재 모음">
  <section class="pt-8 pb-16">
    <div class="container">
      <div class="mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Series</h1>
        <p class="text-muted">하나의 주제를 순서대로 파고드는 연재 모음입니다.</p>
      </div>

      {
        allSeries.length === 0 ? (
          <p class="text-muted">아직 연재 중인 시리즈가 없습니다.</p>
        ) : (
          <div class="grid grid-cols-2 gap-5 max-[640px]:grid-cols-1">
            {allSeries.map((series) => {
              const latest = series.posts[series.posts.length - 1]!;
              return (
                <a
                  href={`/series/${series.id}`}
                  class="border-line-brand bg-surface/90 shadow-card hover:border-brand/25 flex flex-col gap-3 rounded-[20px] border p-6 transition duration-200 hover:-translate-y-1"
                >
                  <span class="bg-brand-soft text-brand inline-flex w-fit items-center rounded-full px-[10px] py-1.5 text-[13px] font-bold">
                    연재 {series.posts.length}편
                  </span>
                  <h2 class="text-text text-[22px] leading-[1.3] font-bold">{series.name}</h2>
                  {series.description && <p class="text-muted">{series.description}</p>}
                  <p class="text-muted text-sm">
                    최근 업데이트 {formatDate(latest.data.pubDate)} · {latest.data.title}
                  </p>
                </a>
              );
            })}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
