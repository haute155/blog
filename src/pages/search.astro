---
import BaseLayout from "../layouts/BaseLayout.astro";
import Search from "astro-pagefind/components/Search.astro";
---

<BaseLayout title="Search | Azure Notes" description="블로그 글 검색">
  <section class="pt-8 pb-16">
    <div class="container max-w-[760px]">
      <div class="mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Search</h1>
        <p class="text-muted">
          제목과 본문 전체에서 검색합니다. 검색 인덱스는 빌드 시 생성되므로 개발 서버에서는 먼저
          <code class="bg-brand-soft text-brand rounded px-1.5 py-0.5 text-sm">npm run build</code>가
          필요합니다.
        </p>
      </div>

      <Search className="pagefind-ui" searchboxOptions={{ autofocus: true }} />
    </div>
  </section>
</BaseLayout>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-primary: var(--c-brand);
    --pagefind-ui-text: var(--c-text);
    --pagefind-ui-background: var(--c-surface);
    --pagefind-ui-border: var(--c-line);
    --pagefind-ui-tag: var(--c-brand-soft);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 16px;
    --pagefind-ui-font: var(--font-sans);
  }
</style>
