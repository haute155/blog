---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../utils/date";
import Chip from "../components/Chip.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const notes = await getCollection("notes", ({ data }) => !data.draft);

const latestPosts = posts.slice(0, 12);

const tagCounts = new Map<string, number>();
for (const entry of [...posts, ...notes]) {
  for (const tag of entry.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<BaseLayout>
  <!-- Hero -->
  <section class="pt-[150px]">
    <div class="container">
      <h1 class="rise text-text font-bold tracking-[-0.02em] text-2xl">
        안녕하세요. 오뜨입니다.
      </h1>
    </div>
  </section>

  <!-- Latest posts -->
  <section>
    <div class="container rise" style="--rise:2">
      <h2 class="text-xl text-brand-glow font-bold tracking-[-0.03em] mt-15 mb-5" >최근 글</h2>

      <ul class="divide-line divide-y" >
        {
          latestPosts.map((post) => (
            <li class="py-2 first:pt-0">
              <a href={`/posts/${post.id}`} class="group block ">
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="text-text group-hover:text-brand text-lg font-bold transition-colors">
                    {post.data.title}
                  </h3>
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="text-muted shrink-0 text-sm"
                  >
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                <p class="text-muted line-clamp-1">{post.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 태그 바로가기 -->
  <section class="mt-15">
    <div class="container grid grid-cols-2 gap-5 max-[768px]:grid-cols-1">
      {
        tags.length > 0 && (
          <div class="rise" style="--rise: 6">
            <h2 class="text-brand-glow mb-5 text-xl font-bold">태그</h2>
            <div class="flex flex-wrap gap-2">
              {tags.map(([tag, count]) => (
                <Chip href={`/tags/${tag}`} size="md">
                  {tag}
                  <span class="bg-surface/80 text-muted rounded-full px-1.5 text-xs font-bold">
                    {count}
                  </span>
                </Chip>
              ))}
            </div>
          </div>
        )
      }

    </div>
  </section>
</BaseLayout>
