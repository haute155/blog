---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import TagFilter from "../../components/TagFilter.astro";
import { getSeriesNameMap } from "../../utils/series";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/date";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(posts, { pageSize: 9 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const seriesNames = await getSeriesNameMap();
---

<BaseLayout title="Blog" description="오뜨와 커피 한 잔 전체 글 목록">
  <section class="pt-8 pb-16">
    <div class="container">
      <div class="mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Blog</h1>
        <p class="text-muted">프론트엔드, UI, 성능, 개발 회고에 대한 글을 모아두었습니다.</p>
      </div>

      <div class="mb-8">
        <TagFilter />
      </div>

      <div class="grid grid-cols-3 gap-5 max-[900px]:grid-cols-2 max-[640px]:grid-cols-1">
        {
          page.data.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              pubDate={formatDate(post.data.pubDate)}
              tag={post.data.tags[0]}
              seriesName={post.data.series && seriesNames.get(post.data.series.id)}
            />
          ))
        }
      </div>

      {
        page.lastPage > 1 && (
          <nav aria-label="페이지네이션" class="mt-10 flex items-center justify-center gap-4">
            {page.url.prev && (
              <a
                href={page.url.prev}
                class="border-line-brand bg-surface hover:border-brand/40 rounded-full border px-4 py-2 font-semibold transition-colors"
              >
                ← 이전
              </a>
            )}
            <span class="text-muted text-sm">
              {page.currentPage} / {page.lastPage}
            </span>
            {page.url.next && (
              <a
                href={page.url.next}
                class="border-line-brand bg-surface hover:border-brand/40 rounded-full border px-4 py-2 font-semibold transition-colors"
              >
                다음 →
              </a>
            )}
          </nav>
        )
      }
    </div>
  </section>
</BaseLayout>
