---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import TagFilter from "../../components/TagFilter.astro";
import { getAllSeries } from "../../utils/series";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/date";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(posts, { pageSize: 9 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
// 시리즈 소개는 첫 페이지에만 노출
const seriesList = page.currentPage === 1 ? [...(await getAllSeries()).entries()] : [];
---

<BaseLayout title="Blog | Azure Notes" description="Azure Notes 전체 글 목록">
  <section class="pt-8 pb-16">
    <div class="container">
      <div class="mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Blog</h1>
        <p class="text-muted">프론트엔드, UI, 성능, 개발 회고에 대한 글을 모아두었습니다.</p>
      </div>

      {
        seriesList.length > 0 && (
          <div class="mb-8">
            <h2 class="text-text mb-3 text-sm font-extrabold tracking-wide uppercase">
              시리즈 연재
            </h2>
            <div class="grid grid-cols-2 gap-4 max-[640px]:grid-cols-1">
              {seriesList.map(([name, posts]) => (
                <a
                  href={`/series/${name}`}
                  class="border-brand/20 bg-brand-soft/60 hover:border-brand/40 flex items-center justify-between gap-3 rounded-2xl border p-5 transition-colors"
                >
                  <div class="min-w-0">
                    <span class="text-text block truncate font-extrabold">{name}</span>
                    <span class="text-muted text-sm">총 {posts.length}편</span>
                  </div>
                  <span class="text-brand shrink-0 font-bold">→</span>
                </a>
              ))}
            </div>
          </div>
        )
      }

      <div class="mb-8">
        <TagFilter />
      </div>

      <div class="grid grid-cols-3 gap-5 max-[900px]:grid-cols-2 max-[640px]:grid-cols-1">
        {
          page.data.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              pubDate={formatDate(post.data.pubDate)}
              tag={post.data.tags[0]}
            />
          ))
        }
      </div>

      {
        page.lastPage > 1 && (
          <nav aria-label="페이지네이션" class="mt-10 flex items-center justify-center gap-4">
            {page.url.prev && (
              <a
                href={page.url.prev}
                class="border-line-brand bg-surface hover:border-brand/40 rounded-full border px-4 py-2 font-semibold transition-colors"
              >
                ← 이전
              </a>
            )}
            <span class="text-muted text-sm">
              {page.currentPage} / {page.lastPage}
            </span>
            {page.url.next && (
              <a
                href={page.url.next}
                class="border-line-brand bg-surface hover:border-brand/40 rounded-full border px-4 py-2 font-semibold transition-colors"
              >
                다음 →
              </a>
            )}
          </nav>
        )
      }
    </div>
  </section>
</BaseLayout>
