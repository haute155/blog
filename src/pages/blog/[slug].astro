---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import * as mdxComponents from "../../components/mdx/index";
import { formatDate } from "../../utils/date";
import { getReadingTime } from "../../utils/readingTime";
import { getSeriesById } from "../../utils/series";
import { SITE_AUTHOR } from "../../consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      // 최신순 정렬이므로 이전 글 = 다음 인덱스
      prevPost: posts[i + 1] ?? null,
      nextPost: posts[i - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

const series = post.data.series ? await getSeriesById(post.data.series.id) : undefined;
const seriesPosts = series?.posts ?? [];
const seriesIndex = seriesPosts.findIndex((p) => p.id === post.id);

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const readingTime = getReadingTime(post.body);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  keywords: post.data.tags.join(", "),
  author: { "@type": "Person", name: SITE_AUTHOR },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <article class="pt-14 pb-20" data-pagefind-body>
    <div class="container max-w-[760px]">
      <div class="flex flex-wrap gap-2">
        {
          post.data.tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="bg-brand-soft text-brand hover:bg-brand inline-flex w-fit items-center rounded-full px-[10px] py-1.5 text-[13px] font-bold transition-colors hover:text-white"
            >
              {tag}
            </a>
          ))
        }
      </div>
      <h1
        class="mt-4 mb-3 text-[clamp(36px,5vw,54px)] leading-[1.1] font-extrabold tracking-[-0.04em]"
      >
        {post.data.title}
      </h1>
      <div class="text-muted text-sm">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span aria-hidden="true"> · </span>{readingTime}분 읽기
      </div>

      {
        series && seriesPosts.length > 1 && (
          <aside
            aria-label="시리즈"
            class="border-brand/20 bg-brand-soft/60 mt-7 rounded-2xl border p-5"
            data-pagefind-ignore
          >
            <p class="text-brand mb-1 text-sm font-extrabold tracking-wide uppercase">시리즈</p>
            <a href={`/series/${series.id}`} class="text-text hover:text-brand text-lg font-extrabold">
              {series.name}
            </a>
            <span class="text-muted ml-2 text-sm font-semibold">
              {seriesIndex + 1} / {seriesPosts.length}편
            </span>
            <ol class="mt-3 space-y-1.5 text-[15px]">
              {seriesPosts.map((p, i) => (
                <li class="flex gap-2">
                  <span class="text-brand w-5 shrink-0 text-right font-bold">{i + 1}.</span>
                  {p.id === post.id ? (
                    <span class="text-text font-bold" aria-current="page">
                      {p.data.title}
                    </span>
                  ) : (
                    <a href={`/blog/${p.id}`} class="text-muted hover:text-brand transition-colors">
                      {p.data.title}
                    </a>
                  )}
                </li>
              ))}
            </ol>
          </aside>
        )
      }

      {
        toc.length > 1 && (
          <nav
            id="toc-inline"
            aria-label="목차"
            class="border-line-brand bg-surface/60 mt-7 rounded-2xl border p-5"
            data-pagefind-ignore
          >
            <p class="text-text mb-2 text-sm font-extrabold tracking-wide uppercase">목차</p>
            <ul class="toc-list text-[15px]">
              {toc.map((heading) => (
                <li data-depth={heading.depth}>
                  <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      <div class="prose">
        <Content components={mdxComponents} />
      </div>

      <nav aria-label="이전/다음 글" class="mt-10 grid grid-cols-2 gap-4 max-sm:grid-cols-1">
        {
          prevPost ? (
            <a
              href={`/blog/${prevPost.id}`}
              class="border-line-brand bg-surface/90 hover:border-brand/25 rounded-2xl border p-5 transition-colors"
            >
              <div class="text-muted mb-1 text-sm">← 이전 글</div>
              <div class="text-text font-bold">{prevPost.data.title}</div>
            </a>
          ) : (
            <span />
          )
        }
        {
          nextPost && (
            <a
              href={`/blog/${nextPost.id}`}
              class="border-line-brand bg-surface/90 hover:border-brand/25 rounded-2xl border p-5 text-right transition-colors"
            >
              <div class="text-muted mb-1 text-sm">다음 글 →</div>
              <div class="text-text font-bold">{nextPost.data.title}</div>
            </a>
          )
        }
      </nav>
    </div>

    {
      toc.length > 1 && (
        <aside
          id="toc-floating"
          aria-label="플로팅 목차"
          data-pagefind-ignore
          class="border-line-brand bg-surface/95 shadow-card fixed top-1/2 left-[calc(50%+380px+28px)] z-20 hidden w-[230px] rounded-2xl border p-4 backdrop-blur-sm xl:block"
        >
          <p class="text-text mb-2 text-xs font-extrabold tracking-wide uppercase">목차</p>
          <ul class="toc-list max-h-[60vh] overflow-y-auto text-[13.5px] leading-snug">
            {toc.map((heading) => (
              <li data-depth={heading.depth}>
                <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
</BaseLayout>

<style>
  /* ─── 목차 위계: h2는 진하고 크게, h3는 연하고 작게 들여쓰기 ─── */
  .toc-list a {
    display: block;
    padding-block: 2px;
    color: var(--c-muted);
    transition: color 0.15s ease;
  }

  .toc-list a:hover {
    color: var(--c-brand);
  }

  .toc-list li[data-depth="2"] > a {
    color: var(--c-text);
    font-weight: 650;
  }

  /* h2 그룹 사이 간격 (첫 항목 제외) */
  .toc-list li[data-depth="2"]:not(:first-child) {
    margin-top: 0.7em;
  }

  .toc-list li[data-depth="3"] > a {
    font-size: 0.88em;
    padding-left: 1.1em;
    border-left: 2px solid var(--c-line);
    margin-left: 0.15em;
  }

  /* 현재 읽는 섹션 */
  .toc-list a.toc-active {
    color: var(--c-brand);
    font-weight: 700;
  }

  .toc-list li[data-depth="3"] > a.toc-active {
    border-left-color: var(--c-brand);
  }

  /* 숨김 상태: 오른쪽에 살짝 밀려 있다가 */
  #toc-floating {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-50%) translateX(28px) scale(0.9);
    transition:
      opacity 0.2s ease,
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); /* "또잉" — 오버슈트 스프링 */
  }

  /* 본문 상단 목차가 화면에서 사라지면 튀어나온다 */
  #toc-floating.toc-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    #toc-floating {
      transition: opacity 0.2s ease;
      transform: translateY(-50%);
    }
  }
</style>

<script>
  // 페이지 전환(View Transitions)마다 다시 초기화. 이전 페이지의
  // 리스너/옵저버는 AbortController와 disconnect로 정리한다.
  let cleanup: (() => void) | undefined;

  function initToc() {
    cleanup?.();

    const inlineToc = document.getElementById("toc-inline");
    const floatingToc = document.getElementById("toc-floating");
    if (!inlineToc || !floatingToc) return;

    // 1) 본문 상단 목차가 뷰포트 위로 사라지면 플로팅 목차 표시
    const visibility = new IntersectionObserver(([entry]) => {
      if (!entry) return;
      const scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0;
      floatingToc.classList.toggle("toc-visible", scrolledPast);
    });
    visibility.observe(inlineToc);

    // 2) 스크롤 스파이 — 지금 읽는 섹션 하이라이트
    const headings = [...document.querySelectorAll(".prose h2[id], .prose h3[id]")];
    const links = [...document.querySelectorAll("[data-toc-link]")];
    const controller = new AbortController();
    let ticking = false;

    function highlightCurrent() {
      ticking = false;
      let currentId = headings[0]?.id;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= 120) currentId = heading.id;
        else break;
      }

      // 마지막 섹션이 짧으면 판정선(120px)까지 올라오지 못하므로,
      // 페이지 맨 아래에 도달하면 마지막 항목을 활성화한다
      const nearBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
      if (nearBottom) currentId = headings[headings.length - 1]?.id;
      for (const link of links) {
        link.classList.toggle("toc-active", link.getAttribute("data-toc-link") === currentId);
      }
    }

    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(highlightCurrent);
      },
      { passive: true, signal: controller.signal },
    );
    highlightCurrent();

    cleanup = () => {
      visibility.disconnect();
      controller.abort();
    };
  }

  initToc();
  document.addEventListener("astro:page-load", initToc);
</script>
