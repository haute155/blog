---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import * as mdxComponents from "../../components/mdx/index";
import { formatDate } from "../../utils/date";
import { getReadingTime } from "../../utils/readingTime";
import { getSeriesById } from "../../utils/series";
import { SITE_AUTHOR } from "../../consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      // ВхюВІаВѕю ВаЋвагВЮ┤в»ђвАю ВЮ┤Ваё ЖИђ = вІцВЮї ВЮИвЇ▒Віц
      prevPost: posts[i + 1] ?? null,
      nextPost: posts[i - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

const series = post.data.series ? await getSeriesById(post.data.series.id) : undefined;
const seriesPosts = series?.posts ?? [];
const seriesIndex = seriesPosts.findIndex((p) => p.id === post.id);

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const readingTime = getReadingTime(post.body);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  keywords: post.data.tags.join(", "),
  author: { "@type": "Person", name: SITE_AUTHOR },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <article class="pt-14 pb-20" data-pagefind-body>
    <div class="container max-w-[760px]">
      <div class="flex flex-wrap gap-2">
        {
          post.data.tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="bg-brand-soft text-brand hover:bg-brand inline-flex w-fit items-center rounded-full px-[10px] py-1.5 text-[13px] font-bold transition-colors hover:text-white"
            >
              {tag}
            </a>
          ))
        }
      </div>
      <h1
        class="mt-4 mb-3 text-[clamp(36px,5vw,54px)] leading-[1.1] font-extrabold tracking-[-0.04em]"
      >
        {post.data.title}
      </h1>
      <div class="text-muted text-sm">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span aria-hidden="true"> ┬и </span>{readingTime}вХё ВЮйЖИ░
      </div>

      {
        series && seriesPosts.length > 1 && (
          <aside
            aria-label="ВІювдгВдѕ"
            class="border-brand/20 bg-brand-soft/60 mt-7 rounded-2xl border p-5"
            data-pagefind-ignore
          >
            <p class="text-brand mb-1 text-sm font-extrabold tracking-wide uppercase">ВІювдгВдѕ</p>
            <a href={`/series/${series.id}`} class="text-text hover:text-brand text-lg font-extrabold">
              {series.name}
            </a>
            <span class="text-muted ml-2 text-sm font-semibold">
              {seriesIndex + 1} / {seriesPosts.length}ьјИ
            </span>
            <ol class="mt-3 space-y-1.5 text-[15px]">
              {seriesPosts.map((p, i) => (
                <li class="flex gap-2">
                  <span class="text-brand w-5 shrink-0 text-right font-bold">{i + 1}.</span>
                  {p.id === post.id ? (
                    <span class="text-text font-bold" aria-current="page">
                      {p.data.title}
                    </span>
                  ) : (
                    <a href={`/blog/${p.id}`} class="text-muted hover:text-brand transition-colors">
                      {p.data.title}
                    </a>
                  )}
                </li>
              ))}
            </ol>
          </aside>
        )
      }

      {
        toc.length > 1 && (
          <nav
            id="toc-inline"
            aria-label="вфЕВ░е"
            class="border-line-brand bg-surface/60 mt-7 rounded-2xl border p-5"
            data-pagefind-ignore
          >
            <p class="text-text mb-2 text-sm font-extrabold tracking-wide uppercase">вфЕВ░е</p>
            <ul class="space-y-1.5 text-[15px]">
              {toc.map((heading) => (
                <li class:list={[heading.depth === 3 && "pl-4"]}>
                  <a
                    href={`#${heading.slug}`}
                    data-toc-link={heading.slug}
                    class="text-muted hover:text-brand transition-colors"
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      <div class="prose">
        <Content components={mdxComponents} />
      </div>

      <nav aria-label="ВЮ┤Ваё/вІцВЮї ЖИђ" class="mt-10 grid grid-cols-2 gap-4 max-sm:grid-cols-1">
        {
          prevPost ? (
            <a
              href={`/blog/${prevPost.id}`}
              class="border-line-brand bg-surface/90 hover:border-brand/25 rounded-2xl border p-5 transition-colors"
            >
              <div class="text-muted mb-1 text-sm">Рєљ ВЮ┤Ваё ЖИђ</div>
              <div class="text-text font-bold">{prevPost.data.title}</div>
            </a>
          ) : (
            <span />
          )
        }
        {
          nextPost && (
            <a
              href={`/blog/${nextPost.id}`}
              class="border-line-brand bg-surface/90 hover:border-brand/25 rounded-2xl border p-5 text-right transition-colors"
            >
              <div class="text-muted mb-1 text-sm">вІцВЮї ЖИђ Рєњ</div>
              <div class="text-text font-bold">{nextPost.data.title}</div>
            </a>
          )
        }
      </nav>
    </div>

    {
      toc.length > 1 && (
        <aside
          id="toc-floating"
          aria-label="ьћївАюьїЁ вфЕВ░е"
          data-pagefind-ignore
          class="border-line-brand bg-surface/95 shadow-card fixed top-1/2 right-6 z-20 hidden w-[230px] rounded-2xl border p-4 backdrop-blur-sm xl:block"
        >
          <p class="text-text mb-2 text-xs font-extrabold tracking-wide uppercase">вфЕВ░е</p>
          <ul class="max-h-[60vh] space-y-1 overflow-y-auto text-[13px] leading-snug">
            {toc.map((heading) => (
              <li class:list={[heading.depth === 3 && "pl-3"]}>
                <a
                  href={`#${heading.slug}`}
                  data-toc-link={heading.slug}
                  class="text-muted hover:text-brand block py-0.5 transition-colors"
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
</BaseLayout>

<style>
  /* ВѕеЖ╣ђ ВЃЂьЃю: ВўцвЦИВфйВЌљ Вѓ┤ВДЮ в░ђвац ВъѕвІцЖ░ђ */
  #toc-floating {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-50%) translateX(28px) scale(0.9);
    transition:
      opacity 0.2s ease,
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1); /* "вўљВъЅ" Рђћ Вўцв▓ёВіѕьіИ ВіцьћёвДЂ */
  }

  /* в│ИвгИ ВЃЂвІе вфЕВ░еЖ░ђ ьЎћвЕ┤ВЌљВёю ВѓгвЮ╝ВДђвЕ┤ ьіђВќ┤вѓўВўевІц */
  #toc-floating.toc-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    #toc-floating {
      transition: opacity 0.2s ease;
      transform: translateY(-50%);
    }
  }
</style>

<script>
  // ьјўВЮ┤ВДђ ВаёьЎў(View Transitions)вДѕвІц вІцВІю В┤ѕЖИ░ьЎћ. ВЮ┤Ваё ьјўВЮ┤ВДђВЮў
  // вдгВіцвёѕ/ВўхВађв▓ёвіћ AbortControllerВЎђ disconnectвАю ВаЋвдгьЋювІц.
  let cleanup: (() => void) | undefined;

  function initToc() {
    cleanup?.();

    const inlineToc = document.getElementById("toc-inline");
    const floatingToc = document.getElementById("toc-floating");
    if (!inlineToc || !floatingToc) return;

    // 1) в│ИвгИ ВЃЂвІе вфЕВ░еЖ░ђ ви░ьЈгьіИ ВюёвАю ВѓгвЮ╝ВДђвЕ┤ ьћївАюьїЁ вфЕВ░е ьЉюВІю
    const visibility = new IntersectionObserver(([entry]) => {
      if (!entry) return;
      const scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0;
      floatingToc.classList.toggle("toc-visible", scrolledPast);
    });
    visibility.observe(inlineToc);

    // 2) ВіцьЂгвАц ВіцьїїВЮ┤ Рђћ ВДђЖИѕ ВЮйвіћ Вё╣ВЁў ьЋўВЮ┤вЮ╝ВЮ┤ьіИ
    const headings = [...document.querySelectorAll(".prose h2[id], .prose h3[id]")];
    const links = [...document.querySelectorAll("[data-toc-link]")];
    const controller = new AbortController();
    let ticking = false;

    function highlightCurrent() {
      ticking = false;
      let currentId = headings[0]?.id;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= 120) currentId = heading.id;
        else break;
      }
      for (const link of links) {
        const active = link.getAttribute("data-toc-link") === currentId;
        link.classList.toggle("text-brand", active);
        link.classList.toggle("font-bold", active);
        link.classList.toggle("text-muted", !active);
      }
    }

    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(highlightCurrent);
      },
      { passive: true, signal: controller.signal },
    );
    highlightCurrent();

    cleanup = () => {
      visibility.disconnect();
      controller.abort();
    };
  }

  initToc();
  document.addEventListener("astro:page-load", initToc);
</script>
