---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Chip from "../../components/Chip.astro";
import { getCollection, render } from "astro:content";
import * as mdxComponents from "../../components/mdx/index";
import { formatDate } from "../../utils/date";
import { getRelatedPosts } from "../../utils/related";
import { SITE_AUTHOR } from "../../consts";
import ShareButtons from "../../components/ShareButtons.astro";
import Comments from "../../components/Comments.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      // 최신순 정렬이므로 이전 글 = 다음 인덱스
      prevPost: posts[i + 1] ?? null,
      nextPost: posts[i - 1] ?? null,
      relatedPosts: getRelatedPosts(post, posts),
    },
  }));
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  keywords: post.data.tags.join(", "),
  author: { "@type": "Person", name: SITE_AUTHOR },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  image={`/og/posts/${post.id}.png`}
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <article class="pt-14 pb-20" data-pagefind-body>
    <div class="container max-w-[760px]">
      <div class="rise flex flex-wrap gap-2">
        {
          post.data.tags.map((tag) => (
            <Chip href={`/tags/${tag}`}>{tag}</Chip>
          ))
        }
      </div>
      <h1
        class="rise mt-4 mb-3 text-[clamp(36px,5vw,54px)] leading-[1.1] font-extrabold tracking-[-0.04em]"
        style="--rise: 1"
      >
        {post.data.title}
      </h1>
      <div class="rise text-muted text-sm" style="--rise: 2">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        {
          post.data.updatedDate && post.data.updatedDate > post.data.pubDate && (
            <>
              <span aria-hidden="true"> · </span>
              <time datetime={post.data.updatedDate.toISOString()}>
                {formatDate(post.data.updatedDate)} 수정
              </time>
            </>
          )
        }
      </div>


      {
        toc.length > 1 && (
          <nav
            id="toc-inline"
            aria-label="목차"
            class="border-line-brand bg-surface/60 mt-7 rounded-2xl border p-5"
            data-pagefind-ignore
          >
            <p class="text-text mb-2 text-sm font-extrabold tracking-wide uppercase">목차</p>
            <ul class="toc-list text-[15px]">
              {toc.map((heading) => (
                <li data-depth={heading.depth}>
                  <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      <div class="prose">
        <Content components={mdxComponents} />
      </div>

      <ShareButtons title={post.data.title} />

      {
        relatedPosts.length > 0 && (
          <section aria-label="관련 글" class="mt-12" data-pagefind-ignore>
            <h2 class="text-text mb-4 text-xl font-extrabold">이런 글도 있어요</h2>
            <div class="grid grid-cols-3 gap-5 max-[900px]:grid-cols-2 max-[640px]:grid-cols-1">
              {relatedPosts.map((related) => (
                <PostCard
                  href={`/posts/${related.id}`}
                  title={related.data.title}
                  description={related.data.description}
                  pubDate={formatDate(related.data.pubDate)}
                  tag={related.data.tags[0]}
                />
              ))}
            </div>
          </section>
        )
      }

      <Comments />

      <nav aria-label="이전/다음 글" class="mt-10 grid grid-cols-2 gap-4 max-sm:grid-cols-1">
        {
          prevPost ? (
            <a
              href={`/posts/${prevPost.id}`}
              class="border-line-brand bg-surface/90 hover:border-brand/25 rounded-2xl border p-5 transition-colors"
            >
              <div class="text-muted mb-1 text-sm">← 이전 글</div>
              <div class="text-text font-bold">{prevPost.data.title}</div>
            </a>
          ) : (
            <span />
          )
        }
        {
          nextPost && (
            <a
              href={`/posts/${nextPost.id}`}
              class="border-line-brand bg-surface/90 hover:border-brand/25 rounded-2xl border p-5 text-right transition-colors"
            >
              <div class="text-muted mb-1 text-sm">다음 글 →</div>
              <div class="text-text font-bold">{nextPost.data.title}</div>
            </a>
          )
        }
      </nav>
    </div>

    {
      toc.length > 1 && (
        <aside
          id="toc-floating"
          aria-label="플로팅 목차"
          data-pagefind-ignore
          class="border-line-brand bg-surface/50 shadow-card fixed top-1/2 left-[calc(50%+380px+28px)] z-20 hidden w-60 rounded-2xl border p-4 backdrop-blur-sm xl:block"
        >
          <p class="text-text mb-2 text-xs font-extrabold tracking-wide uppercase">목차</p>
          <ul class="toc-list max-h-[60vh] overflow-y-auto text-[13.5px] leading-snug">
            {toc.map((heading) => (
              <li data-depth={heading.depth}>
                <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </article>
  <CodeCopy />
</BaseLayout>

<style>
  /* ─── 목차 위계: h2는 진하고 크게, h3는 연하고 작게 들여쓰기 ─── */
  .toc-list a {
    display: block;
    padding-block: 2px;
    color: var(--c-muted);
    transition: color 0.15s ease;
  }

  .toc-list a:hover {
    color: var(--c-brand);
  }

  .toc-list li[data-depth="2"] > a {
    color: var(--c-text);
    font-weight: 650;
  }

  /* h2 그룹 사이 간격 (첫 항목 제외) */
  .toc-list li[data-depth="2"]:not(:first-child) {
    margin-top: 0.7em;
  }

  .toc-list li[data-depth="3"] > a {
    font-size: 0.88em;
    padding-left: 1.1em;
    border-left: 2px solid var(--c-line);
    margin-left: 0.15em;
  }

  /* 현재 읽는 섹션 */
  .toc-list a.toc-active {
    color: var(--c-brand);
    font-weight: 700;
  }

  .toc-list li[data-depth="3"] > a.toc-active {
    border-left-color: var(--c-brand);
  }

  /* 숨김 상태: 살짝 아래에 가라앉아 있다가 */
  #toc-floating {
    opacity: 0;
    pointer-events: none;
    transform: translateY(calc(-50% + 20px));
    transition:
      opacity 0.4s ease,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1); /* 은은한 ease-out — 바운스 없음 */
  }

  /* 본문 상단 목차가 화면에서 사라지면 아래에서 위로 떠오른다 */
  #toc-floating.toc-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%);
  }

  @media (prefers-reduced-motion: reduce) {
    #toc-floating {
      transition: opacity 0.2s ease;
      transform: translateY(-50%);
    }
  }
</style>

<script>
  function initToc() {
    const inlineToc = document.getElementById("toc-inline");
    const floatingToc = document.getElementById("toc-floating");
    if (!inlineToc || !floatingToc) return;

    // 1) 본문 상단 목차가 뷰포트 위로 사라지면 플로팅 목차 표시
    const visibility = new IntersectionObserver(([entry]) => {
      if (!entry) return;
      const scrolledPast = !entry.isIntersecting && entry.boundingClientRect.top < 0;
      floatingToc.classList.toggle("toc-visible", scrolledPast);
    });
    visibility.observe(inlineToc);

    // 2) 스크롤 스파이 — 지금 읽는 섹션 하이라이트
    const headings = [...document.querySelectorAll(".prose h2[id], .prose h3[id]")];
    const links = [...document.querySelectorAll("[data-toc-link]")];
    let ticking = false;

    function highlightCurrent() {
      ticking = false;
      let currentId = headings[0]?.id;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= 120) currentId = heading.id;
        else break;
      }

      // 마지막 섹션이 짧으면 판정선(120px)까지 올라오지 못하므로,
      // 페이지 맨 아래에 도달하면 마지막 항목을 활성화한다
      const nearBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
      if (nearBottom) currentId = headings[headings.length - 1]?.id;
      for (const link of links) {
        link.classList.toggle("toc-active", link.getAttribute("data-toc-link") === currentId);
      }
    }

    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(highlightCurrent);
      },
      { passive: true },
    );
    highlightCurrent();
  }

  initToc();
</script>
