---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="페이지를 찾을 수 없습니다">
  <section class="pt-24 pb-32 text-center">
    <div class="container max-w-[560px]">
      <p class="text-brand text-[clamp(64px,10vw,96px)] leading-none font-extrabold">404</p>
      <h1 class="mt-4 mb-3 text-[clamp(24px,4vw,32px)] font-extrabold tracking-[-0.03em]">
        페이지를 찾을 수 없습니다
      </h1>
      <p class="text-muted">주소가 바뀌었거나 삭제된 페이지일 수 있어요.</p>
      <div class="mt-8 flex justify-center gap-3">
        <a
          href="/"
          class="bg-brand-glow hover:bg-brand-dark inline-flex h-[46px] items-center justify-center rounded-full px-[18px] font-bold text-white shadow-button transition-colors duration-200"
        >
          홈으로 가기
        </a>
        <a
          href="/posts"
          class="border-line hover:border-brand/40 inline-flex h-[46px] items-center justify-center rounded-full bg-surface border px-[18px] font-bold transition-colors duration-200"
        >
          글 목록 보기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
