---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Chip from "../../components/Chip.astro";
import { getCollection, render } from "astro:content";
import * as mdxComponents from "../../components/mdx/index";
import { formatDate } from "../../utils/date";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);

  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<BaseLayout
  title={note.data.title}
  description={note.data.description}
  ogType="article"
  image={`/og/notes/${note.id}.png`}
  publishedTime={note.data.pubDate}
>
  <article class="pt-14 pb-20" data-pagefind-body>
    <div class="container max-w-[760px]">
      <div class="rise flex flex-wrap gap-2">
        {
          note.data.tags.map((tag) => (
            <Chip href={`/tags/${tag}`}>🌱 {tag}</Chip>
          ))
        }
      </div>
      <h1
        class="rise mt-4 mb-3 text-[clamp(36px,5vw,54px)] leading-[1.1] font-extrabold tracking-[-0.04em]"
        style="--rise: 1"
      >
        {note.data.title}
      </h1>
      <div class="rise text-muted text-sm" style="--rise: 2">
        <time datetime={note.data.pubDate.toISOString()}>{formatDate(note.data.pubDate)}</time>
      </div>

      <div class="prose">
        <Content components={mdxComponents} />
      </div>
    </div>
  </article>
</BaseLayout>
