---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/date";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf()
);
---

<BaseLayout title="Notes | Azure Notes" description="완성된 글이 아니라 계속 자라는 문서들">
  <section class="pt-8 pb-16">
    <div class="container">
      <div class="mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Notes</h1>
        <p class="text-muted">
          완성된 포스트가 아니라 <strong>자라는 문서</strong>입니다. 경험과 생각이 바뀔 때마다
          업데이트됩니다.
        </p>
      </div>

      <div class="grid grid-cols-3 gap-5 max-[900px]:grid-cols-2 max-[640px]:grid-cols-1">
        {
          notes.map((note) => (
            <PostCard
              href={`/notes/${note.id}`}
              title={note.data.title}
              description={note.data.description}
              pubDate={`업데이트 ${formatDate(note.data.updatedDate)}`}
              tag={note.data.tags[0]}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
