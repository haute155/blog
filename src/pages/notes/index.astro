---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/date";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Notes" description="문제를 만나고 해결한 과정의 기록">
  <section class="pt-8 pb-16">
    <div class="container">
      <div class="rise mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Notes</h1>
        <p class="text-muted">경험과 생각을 적습니다.</p>
      </div>

      <div class="rise grid grid-cols-3 gap-5 max-[900px]:grid-cols-2 max-[640px]:grid-cols-1" style="--rise: 1">
        {
          notes.map((note) => (
            <PostCard
              href={`/notes/${note.id}`}
              title={note.data.title}
              description={note.data.description}
              pubDate={formatDate(note.data.pubDate)}
              tag={note.data.tags[0]}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
