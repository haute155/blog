---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const notes = await getCollection("notes", ({ data }) => !data.draft);

const tagCounts = new Map<string, number>();
for (const entry of [...posts, ...notes]) {
  for (const tag of entry.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<BaseLayout title="Tags | Azure Notes" description="태그별로 글을 모아봅니다">
  <section class="pt-8 pb-16">
    <div class="container">
      <div class="mb-6">
        <h1 class="mb-2 text-[clamp(30px,4vw,44px)] font-extrabold tracking-[-0.03em]">Tags</h1>
        <p class="text-muted">태그를 선택하면 관련 글을 모아볼 수 있습니다.</p>
      </div>

      <div class="flex flex-wrap gap-3">
        {
          tags.map(([tag, count]) => (
            <a
              href={`/tags/${tag}`}
              class="border-line-brand bg-surface/90 text-text hover:border-brand/40 hover:text-brand inline-flex items-center gap-2 rounded-full border px-4 py-2 font-semibold transition-colors"
            >
              {tag}
              <span class="bg-brand-soft text-brand rounded-full px-2 py-0.5 text-xs font-bold">
                {count}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
