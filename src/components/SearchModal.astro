<dialog
  id="search-modal"
  class="border-line-brand bg-surface shadow-card m-auto mt-[12vh] w-[min(560px,90vw)] rounded-2xl border p-0 backdrop:bg-black/40 backdrop:backdrop-blur-sm"
>
  <form action="/search" method="get" class="flex items-center gap-3 p-4">
    <svg
      class="text-muted h-5 w-5 shrink-0"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      viewBox="0 0 24 24"
    >
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="search"
      name="q"
      required
      placeholder="검색어를 입력하세요"
      autocomplete="off"
      aria-label="검색어"
      class="text-text placeholder:text-muted min-w-0 flex-1 bg-transparent text-lg font-medium outline-none"
    />
  </form>

  <div
    id="search-modal-results"
    role="listbox"
    aria-label="검색 결과"
    class="border-line-brand hidden max-h-[45vh] overflow-y-auto border-t p-2"
  >
  </div>

  <p class="text-muted border-line-brand border-t px-4 py-2.5 text-xs">
    <kbd class="bg-brand-soft text-brand rounded px-1.5 py-0.5 font-sans font-bold">↑↓</kbd> 이동 ·
    <kbd class="bg-brand-soft text-brand rounded px-1.5 py-0.5 font-sans font-bold">Enter</kbd>
    이동/전체 결과 ·
    <kbd class="bg-brand-soft text-brand rounded px-1.5 py-0.5 font-sans font-bold">Esc</kbd> 닫기
  </p>
</dialog>

<script>
  // 모두 이벤트 위임 — View Transitions로 DOM이 교체돼도 계속 동작한다.
  const MAX_RESULTS = 8;
  let debounceTimer: ReturnType<typeof setTimeout> | undefined;
  let searchSeq = 0; // 늦게 도착한 이전 검색 응답이 최신 결과를 덮어쓰지 않도록
  let selectedIndex = -1;

  // Pagefind 인덱스는 빌드 산출물이라 Vite가 해석하지 않도록 @vite-ignore
  let pagefindPromise: Promise<{ search: (q: string) => Promise<PagefindResponse> } | null> | null =
    null;

  interface PagefindResponse {
    results: {
      data: () => Promise<{ url: string; excerpt: string; meta: { title?: string } }>;
    }[];
  }

  function getPagefind() {
    // @ts-expect-error — 빌드 시 생성되는 산출물이라 타입 선언이 없다
    pagefindPromise ??= import(/* @vite-ignore */ "/pagefind/pagefind.js")
      .then(async (pf) => {
        await pf.init();
        return pf;
      })
      .catch(() => null);
    return pagefindPromise;
  }

  function getModal() {
    return document.getElementById("search-modal") as HTMLDialogElement | null;
  }

  function getResultsBox() {
    return document.getElementById("search-modal-results");
  }

  function openSearch() {
    const dialog = getModal();
    if (!dialog) return;
    dialog.showModal();
    const input = dialog.querySelector("input");
    input?.focus();
    input?.select();
    if (input?.value) runSearch(input.value);
  }

  function renderMessage(html: string) {
    const box = getResultsBox();
    if (!box) return;
    selectedIndex = -1;
    box.classList.remove("hidden");
    box.innerHTML = `<p class="text-muted px-3 py-2 text-sm">${html}</p>`;
  }

  function hideResults() {
    const box = getResultsBox();
    if (!box) return;
    selectedIndex = -1;
    box.classList.add("hidden");
    box.innerHTML = "";
  }

  async function runSearch(rawQuery: string) {
    const query = rawQuery.trim();
    if (!query) {
      hideResults();
      return;
    }

    const seq = ++searchSeq;
    const pagefind = await getPagefind();
    if (seq !== searchSeq) return;

    if (!pagefind) {
      renderMessage("검색 인덱스가 없습니다. 개발 서버에서는 pnpm build 후 동작해요.");
      return;
    }

    const search = await pagefind.search(query);
    if (seq !== searchSeq) return;

    const items = await Promise.all(search.results.slice(0, MAX_RESULTS).map((r) => r.data()));
    if (seq !== searchSeq) return;

    if (items.length === 0) {
      renderMessage(`“${escapeHtml(query)}”에 대한 결과가 없습니다.`);
      return;
    }

    const box = getResultsBox();
    if (!box) return;
    selectedIndex = -1;
    box.classList.remove("hidden");
    box.innerHTML =
      items
        .map(
          (item, i) => `
            <a
              href="${item.url}"
              role="option"
              aria-selected="false"
              data-result-index="${i}"
              class="hover:bg-brand-soft block rounded-xl px-3 py-2.5 transition-colors"
            >
              <span class="text-text block text-[15px] font-bold">${escapeHtml(item.meta.title ?? item.url)}</span>
              <span class="text-muted mt-0.5 block truncate text-[13px]">${item.excerpt}</span>
            </a>`,
        )
        .join("") +
      `<a
        href="/search?q=${encodeURIComponent(query)}"
        class="text-brand block rounded-xl px-3 py-2.5 text-sm font-bold"
      >전체 결과 보기 (${search.results.length}건) →</a>`;
  }

  function escapeHtml(text: string) {
    return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  function updateSelection(delta: number) {
    const box = getResultsBox();
    if (!box || box.classList.contains("hidden")) return;
    const options = [...box.querySelectorAll("[data-result-index]")] as HTMLAnchorElement[];
    if (options.length === 0) return;

    selectedIndex = (selectedIndex + delta + options.length) % options.length;
    options.forEach((option, i) => {
      const selected = i === selectedIndex;
      option.setAttribute("aria-selected", String(selected));
      option.classList.toggle("bg-brand-soft", selected);
    });
    options[selectedIndex]?.scrollIntoView({ block: "nearest" });
  }

  document.addEventListener("click", (e) => {
    const target = e.target as Element | null;
    if (target?.closest("#search-open")) {
      openSearch();
      return;
    }
    // 백드롭 클릭으로 닫기 — 백드롭 클릭은 dialog 요소 자신이 타깃이 된다
    const dialog = getModal();
    if (dialog?.open && target === dialog) dialog.close();
  });

  document.addEventListener("input", (e) => {
    const input = e.target;
    if (!(input instanceof HTMLInputElement) || !input.closest("#search-modal")) return;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => runSearch(input.value), 150);
  });

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch();
      return;
    }

    const dialog = getModal();
    if (!dialog?.open || e.isComposing) return;

    if (e.key === "ArrowDown" || e.key === "ArrowUp") {
      e.preventDefault();
      updateSelection(e.key === "ArrowDown" ? 1 : -1);
    } else if (e.key === "Enter" && selectedIndex >= 0) {
      // 선택된 결과로 이동. 선택이 없으면 폼 제출로 /search 페이지에 간다.
      const selected = dialog.querySelector(
        `[data-result-index="${selectedIndex}"]`,
      ) as HTMLAnchorElement | null;
      if (selected) {
        e.preventDefault();
        window.location.href = selected.href;
      }
    }
  });
</script>
