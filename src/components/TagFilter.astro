---
import Chip from "./Chip.astro";
import { getCollection } from "astro:content";

interface Props {
  /** 현재 필터 중인 태그 — 없으면 "전체"가 활성 */
  activeTag?: string;
}

const { activeTag } = Astro.props;

const posts = await getCollection("blog", ({ data }) => !data.draft);
const notes = await getCollection("notes", ({ data }) => !data.draft);

const tagCounts = new Map<string, number>();
for (const entry of [...posts, ...notes]) {
  for (const tag of entry.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

---

<nav aria-label="태그 필터" class="flex flex-wrap gap-2">
  <Chip href="/posts" size="md" variant={activeTag ? "soft" : "active"}>전체</Chip>
  {
    tags.map(([tag, count]) => (
      <Chip
        href={`/tags/${tag}`}
        size="md"
        variant={activeTag === tag ? "active" : "soft"}
        aria-current={activeTag === tag ? "page" : undefined}
      >
        {tag}
        <span
          class:list={[
            "rounded-full px-1.5 text-xs font-bold",
            activeTag === tag ? "bg-brand/15 text-brand" : "bg-surface/80 text-muted",
          ]}
        >
          {count}
        </span>
      </Chip>
    ))
  }
</nav>
